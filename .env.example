DUCKDB_PATH=./data/amazon_reviews.duckdb
DATA_DIR=./data
SAMPLE_DATA_DIR=./data/sample
BM25_INDEX_PATH=./data/bm25_index.joblib
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Optional PostgreSQL (used only if POSTGRES_URL is set)
# POSTGRES_URL=postgresql://ari:ari_secret@localhost:5432/amazon_reviews
POSTGRES_USER=ari
POSTGRES_PASSWORD=ari_secret
POSTGRES_DB=amazon_reviews
